# tr-academic-nlp environment variables — TEMPLATE
# Copy this file to `.env` (in the same directory) and fill in your real values.
# `.env` is git-ignored; `.env.example` is committed so others know what to set.

# Google Gemini API key — used for Faz 2 NER labeling (free tier: 1500/day)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic API key — used for Faz 6.5 AI detector data + Faz 7 reasoner CoT
# Get one at: https://console.anthropic.com/
# Optional in Faz 2 if you go Gemini-only.
ANTHROPIC_API_KEY=

# OpenAI API key — used for Faz 6.5 AI detector data (GPT-4o paragraphs)
# Optional; only needed for full 4-class detector training data.
OPENAI_API_KEY=

# HuggingFace token (write scope) — used to push models / datasets
# Get one at: https://huggingface.co/settings/tokens (scope: write)
HF_TOKEN=
